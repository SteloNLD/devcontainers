{
  "name": "iac-spec",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "workspaceMount": "source=${localEnv:HOME}/src,target=${localEnv:HOME}/src,type=bind",
  "workspaceFolder": "${localWorkspaceFolder}",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/stelonld/devcontainer-features/opentofu:1": {},
    "ghcr.io/stelonld/devcontainer-features/packer:1": {},
    "ghcr.io/stelonld/devcontainer-features/tflint:1": {},
    "ghcr.io/devcontainers-extra/features/ansible:2": {},
    "ghcr.io/stelonld/devcontainer-features/ansible-lint:1": {},
    "ghcr.io/stelonld/devcontainer-features/ansible-navigator:1": {},
    "ghcr.io/stelonld/devcontainer-features/direnv:1": {},
    "ghcr.io/devcontainers-extra/features/pre-commit:2": {},
    "ghcr.io/devcontainers-extra/features/sops:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.ansible",
        "redhat.vscode-yaml",
        "hashicorp.terraform",
        "hashicorp.packer",
        "ms-python.python",
        "mkhl.direnv",
        "signageos.signageos-vscode-sops",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}